<h2>Match Scorecard</h2>
<% if (!match) { %>
  <div class="alert alert-danger">Match not found.</div>
<% } else { %>
  <h4><%= match.teamA.name %> vs <%= match.teamB.name %></h4>
  <p>Status: <%= match.status %> <% if (match.winner) { %>| Winner: <strong><%= match.winner.name %></strong><% } %></p>

  <% if (!scorecard) { %>
    <div class="alert alert-info">Scorecard not available yet.</div>
  <% } else { %>
    <h5>Team Scores</h5>
    <ul>
      <% scorecard.teamScores.forEach(ts => { %>
        <li><%= ts.team.name %>: <strong><%= ts.runs %>/<%= ts.wickets %></strong> in <%= ts.overs %> overs</li>
      <% }) %>
    </ul>

    <h5>Batting</h5>
    <table class="table"><tr><th>Player</th><th>Runs</th><th>Balls</th></tr>
      <% scorecard.batting.forEach(b => { %><tr><td><%= b.player.name %></td><td><%= b.runs %></td><td><%= b.balls %></td></tr><% }) %>
    </table>

    <h5>Bowling</h5>
    <table class="table"><tr><th>Player</th><th>Overs</th><th>Wickets</th></tr>
      <% scorecard.bowling.forEach(b => { %><tr><td><%= b.player.name %></td><td><%= b.overs %></td><td><%= b.wickets %></td></tr><% }) %>
    </table>
  <% } %>
<% } %>
