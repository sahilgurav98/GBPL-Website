<h2>Manage Teams</h2>
<form method="POST" action="/admin/teams" class="row g-2 mb-4">
  <div class="col-md-4"><input class="form-control" name="name" placeholder="Team name" required></div>
  <div class="col-md-4"><input class="form-control" name="city" placeholder="Village/City"></div>
  <div class="col-md-2"><button class="btn btn-success">Add Team</button></div>
</form>
<table class="table table-bordered">
  <tr><th>Name</th><th>City</th><th>Actions</th></tr>
  <% teams.forEach(team => { %>
    <tr>
      <td>
        <form action="/admin/teams/<%= team._id %>?_method=PUT" method="POST" class="d-flex gap-2">
          <input class="form-control form-control-sm" name="name" value="<%= team.name %>" required>
      </td>
      <td><input class="form-control form-control-sm" name="city" value="<%= team.city || '' %>"></td>
      <td>
          <button class="btn btn-sm btn-primary">Update</button>
        </form>
        <form action="/admin/teams/<%= team._id %>?_method=DELETE" method="POST" class="d-inline">
          <button class="btn btn-sm btn-danger mt-1">Delete</button>
        </form>
      </td>
    </tr>
  <% }) %>
</table>
