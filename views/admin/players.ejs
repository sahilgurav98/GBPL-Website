<h2>Manage Players</h2>

<!-- ADD PLAYER FORM -->
<form method="POST" action="/admin/players" class="row g-2 mb-4">
  <div class="col-12 col-md-3">
    <input class="form-control" name="name" placeholder="Player name" required>
  </div>

  <div class="col-6 col-md-2">
    <input class="form-control" type="number" name="age" placeholder="Age" required>
  </div>

  <div class="col-12 col-md-3">
    <select class="form-select w-100" name="role" required>
      <option value="batsman">batsman</option>
      <option value="bowler">bowler</option>
      <option value="all-rounder">all-rounder</option>
      <option value="keeper">keeper</option>
    </select>
  </div>

  <div class="col-12 col-md-3">
    <select class="form-select w-100" name="team" required>
      <% teams.forEach(t => { %>
        <option value="<%= t._id %>"><%= t.name %></option>
      <% }) %>
    </select>
  </div>

  <div class="col-12 col-md-1">
    <button class="btn btn-success w-100">Add</button>
  </div>
</form>

<!-- TABLE -->
<div class="table-responsive">
<table class="table table-striped align-middle">
  <thead>
    <tr>
      <th>Name</th>
      <th>Role</th>
      <th>Age</th>
      <th>Team</th>
      <th>Action</th>
    </tr>
  </thead>

  <tbody>
  <% players.forEach(player => { %>
    <tr>
      <td colspan="5">

        <!-- UPDATE FORM -->
        <form
          action="/admin/players/<%= player._id %>?_method=PUT"
          method="POST"
          class="row g-2 align-items-center"
        >
          <div class="col-12 col-md-3">
            <input class="form-control form-control-sm" name="name" value="<%= player.name %>">
          </div>

          <div class="col-12 col-md-3">
            <select class="form-select form-select-sm w-100" name="role">
              <% ['batsman','bowler','all-rounder','keeper'].forEach(r=> { %>
                <option value="<%= r %>" <%= player.role===r ? 'selected' : '' %>><%= r %></option>
              <% }) %>
            </select>
          </div>

          <div class="col-6 col-md-2">
            <input class="form-control form-control-sm" type="number" name="age" value="<%= player.age %>">
          </div>

          <div class="col-12 col-md-3">
            <select class="form-select form-select-sm w-100" name="team">
              <% teams.forEach(t => { %>
                <option value="<%= t._id %>"
                  <%= String(player.team?._id)===String(t._id) ? 'selected' : '' %>>
                  <%= t.name %>
                </option>
              <% }) %>
            </select>
          </div>

          <!-- ACTIONS -->
          <div class="col-12 col-md-1 d-flex flex-column gap-1">
            <button class="btn btn-sm btn-primary">Update</button>
          </div>
        </form>

        <!-- DELETE FORM (separate, not nested) -->
        <form
          action="/admin/players/<%= player._id %>?_method=DELETE"
          method="POST"
          class="mt-1"
        >
          <button class="btn btn-sm btn-danger w-100">Delete</button>
        </form>

      </td>
    </tr>
  <% }) %>
  </tbody>
</table>
</div>
