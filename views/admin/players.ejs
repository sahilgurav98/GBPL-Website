<h2>Manage Players</h2>
<form method="POST" action="/admin/players" class="row g-2 mb-4 form-grid-mobile">
  <div class="col-12 col-md-3"><input class="form-control" name="name" placeholder="Player name" required></div>
  <div class="col-6 col-md-1"><input class="form-control" type="number" name="age" placeholder="Age" required></div>
  <div class="col-6 col-md-2">
    <select class="form-select" name="role" required>
      <option value="batsman">batsman</option><option value="bowler">bowler</option><option value="all-rounder">all-rounder</option><option value="keeper">keeper</option>
    </select>
  </div>
  <div class="col-12 col-md-3">
    <select class="form-select" name="team" required>
      <% teams.forEach(t => { %><option value="<%= t._id %>"><%= t.name %></option><% }) %>
    </select>
  </div>
  <div class="col-12 col-md-2"><button class="btn btn-success">Add Player</button></div>
</form>

<div class="table-responsive">
  <table class="table table-striped align-middle">
    <tr><th>Name</th><th>Role</th><th>Age</th><th>Team</th><th>Action</th></tr>
    <% players.forEach(player => { %>
      <tr>
        <td>
          <form action="/admin/players/<%= player._id %>?_method=PUT" method="POST" class="row g-1 align-items-center">
            <div class="col-12 col-md-4"><input class="form-control form-control-sm" name="name" value="<%= player.name %>"></div>
        </td>
        <td>
            <div class="col-6 col-md-3">
              <select class="form-select form-select-sm" name="role">
                <% ['batsman','bowler','all-rounder','keeper'].forEach(r=> { %>
                  <option value="<%= r %>" <%= player.role===r ? 'selected' : '' %>><%= r %></option>
                <% }) %>
              </select>
            </div>
        </td>
        <td><div class="col-6 col-md-2"><input class="form-control form-control-sm" type="number" name="age" value="<%= player.age %>"></div></td>
        <td>
            <div class="col-12 col-md-3">
              <select class="form-select form-select-sm" name="team">
                <% teams.forEach(t => { %><option value="<%= t._id %>" <%= String(player.team?._id)===String(t._id) ? 'selected' : '' %>><%= t.name %></option><% }) %>
              </select>
            </div>
        </td>
        <td class="admin-inline-actions">
            <button class="btn btn-sm btn-primary">Update</button>
          </form>
          <form action="/admin/players/<%= player._id %>?_method=DELETE" method="POST" class="d-inline"><button class="btn btn-sm btn-danger">Delete</button></form>
        </td>
      </tr>
    <% }) %>
  </table>
</div>
